
# Local backend example: http://localhost:3000/api/v1
API_BASE_URL=https://workforcebd.onrender.com/api/v1

# Log verbosity. One of: debug | info | warn | error.
# Server (route handlers, proxy). Defaults: debug in dev, info in prod.
LOG_LEVEL=debug

# Browser log verbosity (must be NEXT_PUBLIC_ to reach the client bundle).
NEXT_PUBLIC_LOG_LEVEL=debug
